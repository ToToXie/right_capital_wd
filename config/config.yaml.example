server:
  port: ":8080"
  mode: "release"

database:
  host: "127.0.0.1"
  port: 3306
  user: "root"
  password: "123456"
  dbname: "notification_service"
  charset: "utf8mb4"
  max_open_conns: 100
  max_idle_conns: 20

redis:
  host: "127.0.0.1"
  port: 6379
  password: ""
  db: 0
  pool_size: 100

retry:
  cron: "*/10 * * * * *" # 每10秒执行一次重试任务
  batch_size: 100 # 每次重试批量处理100条消息

log:
  level: "info"
  path: "./logs"
